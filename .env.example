# Local: use +asyncpg. Railway Postgres sets DATABASE_URL as postgresql://…; the app rewrites it to +asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proposals
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
# Low Groq TPM tiers: lower these if you see 413 / rate_limit_exceeded (tokens per minute).
# GROQ_MAX_TOKENS_INTAKE=1024
# GROQ_MAX_TOKENS_REQUIREMENTS=1200
# GROQ_MAX_TOKENS_WRITER=2048
# GROQ_MAX_TOKENS_REVIEW=1200
# GROQ_MAX_TOKENS_RETRIEVAL=384
# GROQ_CLIP_RETRIEVAL_BRIEF_CHARS=2000
# GROQ_CLIP_RETRIEVAL_REQ_CHARS=2500
# GROQ_CLIP_RETRIEVAL_CONTEXT_CHARS=4500
# GROQ_CLIP_RAW_REQUIREMENTS_CHARS=5000
# GROQ_CLIP_BRIEF_CHARS=3500
# GROQ_CLIP_REQUIREMENTS_JSON_CHARS=4000
# GROQ_CLIP_PROPOSAL_REVIEW_CHARS=7000
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
